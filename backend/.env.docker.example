# ══════════════════════════════════════════════════════════════════════════════
# LogoDouman — Backend Environment Variables (Docker)
# Copiez ce fichier en .env.docker et remplissez vos valeurs réelles.
# cp backend/.env.docker.example backend/.env.docker
# ══════════════════════════════════════════════════════════════════════════════

# 🌱 Seed automatique au démarrage (true = créer catégories, produits et admin)
SEED_DATA=true
SEED_ADMIN_EMAIL=admin@logodouman.com
SEED_ADMIN_PASSWORD=Admin@2024!

# 🗄️ Base de Données PostgreSQL
DATABASE_URL="postgresql://postgres:logodouman123@postgres:5432/logodouman"
DB_HOST=postgres
DB_PORT=5432
DB_NAME=logodouman
DB_USER=postgres
DB_PASSWORD=logodouman123

# 🔴 Redis
REDIS_URL="redis://:redis123@redis:6379"
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# 🔐 JWT
JWT_SECRET="changez-ce-secret-en-production"
JWT_EXPIRES_IN=24h
REFRESH_TOKEN_SECRET="changez-ce-refresh-secret-en-production"
REFRESH_TOKEN_EXPIRES_IN=7d

# 🌍 Serveur
NODE_ENV=production
PORT=4002
HOST=0.0.0.0

# 🔗 CORS
CORS_ORIGIN=http://localhost:3000,http://frontend:3000,http://127.0.0.1:3000
CORS_CREDENTIALS=true

# 📁 Stockage des fichiers
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif,webp,pdf

# 📊 Logging
LOG_LEVEL=info
LOG_FILE=/app/logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5

# 🔐 Sécurité
BCRYPT_ROUNDS=12
SESSION_SECRET="changez-ce-session-secret-en-production"
COOKIE_SECRET="changez-ce-cookie-secret-en-production"

# 🛡️ Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
RATE_LIMIT_SKIP_SUCCESSFUL_REQUESTS=true

# 📧 Email SMTP (optionnel)
EMAIL_SERVICE=smtp
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="noreply@logodouman.com"

# ══════════════════════════════════════════════════════════════════════════════
# 💳 PAIEMENT — à renseigner obligatoirement pour activer les paiements
# ══════════════════════════════════════════════════════════════════════════════

# ── Afrique (Côte d'Ivoire + UEMOA) ──────────────────────────────────────────
# Paystack : Mobile Money (MTN MoMo, Orange Money, Wave, Moov) + Cartes
# Inscription : https://dashboard.paystack.com/#/settings/developer
PAYSTACK_SECRET_KEY=sk_test_VOTRE_CLE_PAYSTACK_SECRET
PAYSTACK_PUBLIC_KEY=pk_test_VOTRE_CLE_PAYSTACK_PUBLIC

# CinetPay : fallback si Paystack absent
# Inscription : https://cinetpay.com/dashboard/api
CINETPAY_SITE_ID=
CINETPAY_API_KEY=

# ── Europe (France + UE) ──────────────────────────────────────────────────────
# Stripe : Cartes + SEPA
# Inscription : https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_VOTRE_CLE_STRIPE_SECRET
STRIPE_PUBLISHABLE_KEY=pk_test_VOTRE_CLE_STRIPE_PUBLIQUE
STRIPE_WEBHOOK_SECRET=

# ── Livraison Europe ──────────────────────────────────────────────────────────
# Boxtal : Colissimo, Chronopost, Mondial Relay
# Inscription : https://www.boxtal.com/fr/fr/profile/api
BOXTAL_LOGIN=VOTRE_LOGIN_BOXTAL
BOXTAL_PASSWORD=VOTRE_PASSWORD_BOXTAL
BOXTAL_SENDER_CITY=Paris
BOXTAL_SENDER_COUNTRY=FR

# ── Stockage images ───────────────────────────────────────────────────────────
# Cloudinary : hébergement images produits
# Inscription : https://cloudinary.com/console
CLOUDINARY_CLOUD_NAME=VOTRE_CLOUD_NAME
CLOUDINARY_API_KEY=VOTRE_CLOUDINARY_API_KEY
CLOUDINARY_API_SECRET=VOTRE_CLOUDINARY_API_SECRET

# 🚀 Performance
NODE_OPTIONS="--max-old-space-size=512"
UV_THREADPOOL_SIZE=4

# 🌐 Application
APP_NAME="LogoDouman API"
APP_VERSION=2.0.0
API_PREFIX=/api
DOCS_ENABLED=true

# 🔄 Health Check
HEALTH_CHECK_ENDPOINT=/health
HEALTH_CHECK_INTERVAL=30000

# 📊 Métriques
METRICS_ENABLED=false
METRICS_PORT=9090
