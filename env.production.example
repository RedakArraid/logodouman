# =============================================================================
# LOGODOUMAN - Variables d'environnement Production
# =============================================================================
# Copiez ce fichier vers .env.production et remplissez les valeurs
# cp env.production.example .env.production
# =============================================================================

# -----------------------------------------------------------------------------
# Base de données PostgreSQL
# -----------------------------------------------------------------------------
LOGODOUMAN_DB_NAME=logodouman
LOGODOUMAN_DB_USER=postgres
LOGODOUMAN_DB_PASSWORD=CHANGEZ_CE_MOT_DE_PASSE

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
LOGODOUMAN_REDIS_PASSWORD=CHANGEZ_CE_MOT_DE_PASSE_REDIS

# -----------------------------------------------------------------------------
# JWT (Authentification)
# -----------------------------------------------------------------------------
# Générez un secret fort: openssl rand -base64 64
LOGODOUMAN_JWT_SECRET=CHANGEZ_CE_SECRET_JWT
BCRYPT_ROUNDS=12

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
LOGODOUMAN_CORS_ORIGIN=https://logodouman.genea.space,https://apilogodouman.genea.space

# -----------------------------------------------------------------------------
# Cloudinary (Stockage d'images)
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=votre_cloud_name
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# -----------------------------------------------------------------------------
# Frontend
# -----------------------------------------------------------------------------
NEXT_PUBLIC_API_URL=https://apilogodouman.genea.space
NEXT_PUBLIC_SITE_URL=https://logodouman.genea.space
NEXT_PUBLIC_APP_NAME=LogoDouman
NEXT_PUBLIC_APP_VERSION=2.1.0

# -----------------------------------------------------------------------------
# Limites et configuration
# -----------------------------------------------------------------------------
MAX_FILE_SIZE=5242880
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

