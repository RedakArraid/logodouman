# ══════════════════════════════════════════════════════════════════════════════
# LogoDouman — Frontend Environment Variables (Docker)
# Copiez ce fichier en .env.docker et remplissez vos valeurs réelles.
# cp frontend/.env.docker.example frontend/.env.docker
# ══════════════════════════════════════════════════════════════════════════════

# 🔗 API Backend — URL publique (appelée depuis le navigateur)
NEXT_PUBLIC_API_URL=http://localhost:4002

# 🌐 URL publique du site (utilisée pour les meta OG, sitemap, hreflang)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# 🔗 API Backend — URL interne Docker (appelée depuis le serveur Next.js / SSR)
# En production Docker, utiliser le nom du service : http://backend:4002
INTERNAL_API_URL=http://backend:4002

# 🎨 Application
NEXT_PUBLIC_APP_NAME=LogoDouman
NEXT_PUBLIC_APP_VERSION=2.1.0
NEXT_PUBLIC_APP_DESCRIPTION="Plateforme e-commerce Afrique & Europe"

# 🔧 Next.js
NEXT_TELEMETRY_DISABLED=1
NODE_ENV=production
PORT=3000
HOSTNAME=0.0.0.0

# 🔐 Sécurité
NEXT_PUBLIC_SECURE_MODE=true

# 📊 Analytics (désactivé par défaut)
NEXT_PUBLIC_ANALYTICS_ENABLED=false

# 🎨 Thème
NEXT_PUBLIC_THEME_COLOR=#f97316
NEXT_PUBLIC_BRAND_COLOR=#ea580c

# ══════════════════════════════════════════════════════════════════════════════
# 💳 PAIEMENT — clés publiques (affichées côté client, sans risque)
# ══════════════════════════════════════════════════════════════════════════════

# Paystack — Mobile Money Afrique
# https://dashboard.paystack.com/#/settings/developer
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_VOTRE_CLE_PAYSTACK_PUBLIQUE

# Stripe — Cartes + SEPA Europe
# https://dashboard.stripe.com/apikeys
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_VOTRE_CLE_STRIPE_PUBLIQUE
